{
  "experiment_name": "RedJujube_FLAT_Baseline",
  "model_type": "flat_baseline",
  "dataset": "RedJujube",
  "description": "FLAT (Flat-Lattice Transformer) 模型在 RedJujube 数据集上的复现实验",
  
  "data_config": {
    "data_dir": "_2DATA/RedJujube",
    "train_file": "train.conll",
    "dev_file": "dev.conll",
    "test_file": "test.conll",
    "use_lattice": true,
    "lexicon_path": "_2DATA/RedJujube/lexicon/yj_lexicon.txt",
    "max_seq_len": 256,
    "max_lex_num": 50
  },
  
  "model_config": {
    "hidden_size": 512,
    "num_layers": 4,
    "num_heads": 8,
    "ff_size": 2048,
    "dropout": 0.15,
    "embed_dropout": 0.5,
    "attn_dropout": 0.0,
    "four_pos_fusion": "ff",
    "learnable_position": false,
    "layer_preprocess": "n",
    "layer_postprocess": "dan",
    "use_crf": true,
    "scheme": "BMES"
  },
  
  "embedding_config": {
    "char_emb_dim": 50,
    "word_emb_dim": 50,
    "bigram_emb_dim": 50,
    "use_bigram": true,
    "use_char": true,
    "use_word": true,
    "pretrained_char_path": null,
    "pretrained_word_path": "_2DATA/embeddings/gigaword_chn.all.a2b.uni.ite50.vec",
    "norm_char_emb": false,
    "norm_word_emb": true
  },
  
  "training_config": {
    "num_epochs": 100,
    "batch_size": 10,
    "learning_rate": 0.0006,
    "optimizer": "sgd",
    "momentum": 0.9,
    "weight_decay": 0.0,
    "warmup_steps": 0.1,
    "grad_clip": 5.0,
    "early_stop_patience": 25,
    "save_dir": "cache/redjujube_flat_baseline",
    "log_every_steps": 50,
    "eval_every_steps": 200,
    "save_best_only": true
  },
  
  "device_config": {
    "cuda": true,
    "gpu_id": 0,
    "use_amp": false,
    "seed": 42
  },
  
  "notes": [
    "FLAT 模型配置说明：",
    "1. hidden_size=512: 隐藏层维度，需要能被 num_heads 整除",
    "2. num_layers=4: Transformer 编码层数，原论文使用 4 层",
    "3. num_heads=8: 多头注意力头数",
    "4. ff_size=2048: 前馈网络隐藏层维度，通常为 hidden_size 的 4 倍",
    "5. four_pos_fusion='ff': 四位置融合方式，可选 'ff'/'attn'/'gate'",
    "6. dropout=0.15: 主 Dropout 率",
    "7. learning_rate=0.0006: 学习率，原论文使用 6e-4",
    "8. batch_size=10: 批次大小，根据显存调整",
    "9. 使用 YJ 词典（Zhang & Yang 2018）构建 lattice 结构"
  ]
}
